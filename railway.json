{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_22", "npm"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npm run start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
